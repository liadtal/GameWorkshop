[gd_scene load_steps=2 format=3 uid="uid://quick_mainmenu"]

[ext_resource type="Script" path="res://scripts/main_menu.gd" id="1_mm"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_mm")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.10, 0.10, 0.14, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -180.0
offset_right = 150.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12
alignment = 1

[node name="Title" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 48
horizontal_alignment = 1
text = "Quick"

[node name="Subtitle" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.8, 0.7)
theme_override_font_sizes/font_size = 14
horizontal_alignment = 1
text = "Guide Quicky to the exit!"

[node name="Spacer1" type="Control" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)

[node name="PlayButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
focus_neighbor_bottom = NodePath("../TutorialButton")
focus_neighbor_top = NodePath("../QuitButton")
text = "Play"

[node name="TutorialButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
focus_neighbor_top = NodePath("../PlayButton")
focus_neighbor_bottom = NodePath("../LevelSelectButton")
text = "Tutorial"

[node name="LevelSelectButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
focus_neighbor_top = NodePath("../TutorialButton")
focus_neighbor_bottom = NodePath("../DifficultyRow/DifficultyButton")
text = "Level Select"

[node name="DifficultyRow" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="DifficultyButton" type="Button" parent="VBoxContainer/DifficultyRow"]
layout_mode = 2
custom_minimum_size = Vector2(130, 40)
focus_neighbor_top = NodePath("../../LevelSelectButton")
focus_neighbor_bottom = NodePath("../../QuitButton")
text = "Difficulty:"

[node name="DifficultyLabel" type="Label" parent="VBoxContainer/DifficultyRow"]
layout_mode = 2
custom_minimum_size = Vector2(120, 0)
theme_override_colors/font_color = Color(0.3, 0.85, 0.4, 1)
theme_override_font_sizes/font_size = 20
horizontal_alignment = 0
vertical_alignment = 1
text = "Easy"

[node name="QuitButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
focus_neighbor_top = NodePath("../DifficultyRow/DifficultyButton")
focus_neighbor_bottom = NodePath("../PlayButton")
text = "Quit"

[connection signal="pressed" from="VBoxContainer/PlayButton" to="." method="_on_play_pressed"]
[connection signal="pressed" from="VBoxContainer/TutorialButton" to="." method="_on_tutorial_pressed"]
[connection signal="pressed" from="VBoxContainer/LevelSelectButton" to="." method="_on_level_select_pressed"]
[connection signal="pressed" from="VBoxContainer/DifficultyRow/DifficultyButton" to="." method="_on_difficulty_pressed"]
[connection signal="pressed" from="VBoxContainer/QuitButton" to="." method="_on_quit_pressed"]
